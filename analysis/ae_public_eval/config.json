{
  "dataset_name": "RanSAP",
  "source_mode": "public_ransap",
  "dataset_root": "data/raw/RanSAP/dataset",
  "out_dir": "analysis/ae_public_eval/results/public_ransap",
  "seed": 17,
  "train_fraction": 0.6,
  "calibration_fraction": 0.2,
  "threshold_quantile": 0.99,
  "include_unknown": false,
  "feature": {
    "window_seconds": 10.0,
    "sequence_length": 12,
    "stride": 1,
    "include_entropy": true
  },
  "model": {
    "type": "numpy_mlp",
    "latent_dim": 8,
    "hidden_dim": 32,
    "epochs": 50,
    "batch_size": 64,
    "learning_rate": 0.001
  },
  "label_rules": [
    {
      "label": "attack",
      "patterns": [
        "(?i)ransom",
        "(?i)wannacry",
        "(?i)cerber",
        "(?i)locky",
        "(?i)gandcrab",
        "(?i)revil",
        "(?i)sodinokibi",
        "(?i)conti",
        "(?i)crypt"
      ]
    },
    {
      "label": "benign",
      "patterns": [
        "(?i)benign",
        "(?i)normal",
        "(?i)chrome",
        "(?i)firefox",
        "(?i)edge",
        "(?i)office",
        "(?i)word",
        "(?i)excel",
        "(?i)powerpoint",
        "(?i)explorer",
        "(?i)copy",
        "(?i)7zip",
        "(?i)vlc"
      ]
    }
  ]
}
